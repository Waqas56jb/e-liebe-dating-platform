{
  "expo": {
    "name": "E-Liebe",
    "slug": "e-liebe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/splash.png",
    "scheme": "eliebe",
    "userInterfaceStyle": "light",
    "backgroundColor": "#1A1018",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eliebe.app"
    },
    "android": {
      "package": "com.eliebe.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/splash.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/splash.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "E-Liebe needs access to your photos so you can add them to your profile."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#1E0A2E"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "c6660df4-e16e-4294-b66f-0770a5617eaf"
      }
    },
    "owner": "waqas5656jb"
  }
}
